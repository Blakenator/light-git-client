{
  "productName": "Light-Git",
  "appId": "com.blakestacks.light-git-client",
  "directories": {
    "output": "app-builds"
  },
  "artifactName": "light-git-${version}.${ext}",
  "files": [
    "dist/**",
    "packages/backend/dist/**",
    "packages/backend/src/preload.js",
    "packages/shared/dist/**",
    "packages/core/dist/**",
    "src/*.png"
  ],
  "extraFiles": ["extra/**/*"],
  "publish": [
    {
      "provider": "github",
      "owner": "Blakenator",
      "repo": "light-git-client"
    }
  ],
  "win": {
    "icon": "dist",
    "target": ["nsis", "portable", "7z", "zip"]
  },
  "mac": {
    "icon": "dist",
    "target": ["dmg", "zip"]
  },
  "linux": {
    "icon": "dist",
    "category": "Development",
    "target": ["AppImage", "deb"]
  }
}
